{
  "name": "team-topologies-modeler",
  "private": true,
  "version": "0.4.0",
  "displayName": "Team Topologies Modeler",
  "description": "View and edit Team Topologies diagrams directly in VS Code, including .tt and .ttm.json files.",
  "publisher": "miragon-gmbh",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Miragon/team-topologies-modeler.git",
    "directory": "apps/vscode"
  },
  "bugs": "https://github.com/Miragon/team-topologies-modeler/issues",
  "homepage": "https://github.com/Miragon/team-topologies-modeler/tree/main/apps/vscode#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "team topologies",
    "team",
    "topology",
    "diagram",
    "architecture"
  ],
  "main": "./dist/extension.cjs",
  "type": "module",
  "activationEvents": [
    "onCustomEditor:teamTopologies.editor",
    "onCustomEditor:teamTopologies.pngEditor"
  ],
  "contributes": {
    "languages": [
      {
        "id": "team-topologies",
        "aliases": [
          "Team Topologies",
          "team-topologies"
        ],
        "extensions": [
          ".tt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "teamTopologies.editor",
        "displayName": "Team Topologies Diagram",
        "selector": [
          {
            "filenamePattern": "*.tt"
          },
          {
            "filenamePattern": "*.ttm.json"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "teamTopologies.pngEditor",
        "displayName": "Team Topologies Diagram (PNG)",
        "selector": [
          {
            "filenamePattern": "*.tt.png"
          },
          {
            "filenamePattern": "*.ttm.png"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "teamTopologies.newDiagram",
        "title": "New Empty Diagram",
        "category": "Team Topologies",
        "shortTitle": "Team Topologies"
      },
      {
        "command": "teamTopologies.newFromExample",
        "title": "New Diagram from Example",
        "category": "Team Topologies"
      },
      {
        "command": "teamTopologies.newPngDiagram",
        "title": "New Empty Diagram (embedded PNG)",
        "category": "Team Topologies"
      }
    ],
    "menus": {
      "file/newFile": [
        {
          "command": "teamTopologies.newDiagram",
          "group": "teamTopologies"
        },
        {
          "command": "teamTopologies.newPngDiagram",
          "group": "teamTopologies"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "getStarted",
        "title": "Get Started with Team Topologies Modeler",
        "description": "Create and edit Team Topologies diagrams — the four team types, three interaction modes, and flow-of-change — directly in VS Code.",
        "steps": [
          {
            "id": "create",
            "title": "Create your first diagram",
            "description": "Start from the bundled example or a blank canvas — it opens right in the visual editor.\n[Create diagram from example](command:teamTopologies.newFromExample)",
            "media": {
              "markdown": "media/walkthrough/create.md"
            },
            "completionEvents": [
              "onCommand:teamTopologies.newFromExample"
            ]
          },
          {
            "id": "learn",
            "title": "Learn the basics",
            "description": "Get to know the four team types, the three interaction modes, and how to draw teams and interactions on the canvas.",
            "media": {
              "markdown": "media/walkthrough/learn.md"
            },
            "completionEvents": [
              "onStepSelected"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc -p tsconfig.json",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "vsce package --no-dependencies -o team-topologies-modeler.vsix"
  },
  "dependencies": {
    "@miragon/team-topologies-renderer": "0.4.0",
    "@miragon/team-topologies-schema-model": "0.4.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/vscode": "1.96.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "typescript": "6.0.3"
  }
}

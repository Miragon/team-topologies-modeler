{
  "name": "team-topologies-modeler",
  "version": "0.5.0",
  "private": true,
  "description": "A web-based modeler and VS Code extension for the Team Topologies notation (team types & interaction modes).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": [
    "packages/schema-model",
    "packages/renderer",
    "apps/webapp",
    "apps/vscode",
    "e2e"
  ],
  "scripts": {
    "build": "npm run build -w packages/schema-model -w packages/renderer",
    "build:webapp": "npm run build -w apps/webapp",
    "build:vscode": "npm run build -w apps/vscode",
    "typecheck": "tsc -p tsconfig.json && npm run typecheck -w apps/vscode && npm run typecheck -w e2e",
    "lint": "eslint . && npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser",
    "test:e2e": "npm run test:e2e -w e2e",
    "dev": "npm run dev:webapp",
    "dev:webapp": "npm run dev -w apps/webapp",
    "dev:webapp:plain": "npm run dev:app -w apps/webapp",
    "dev:vscode": "npm run watch -w apps/vscode",
    "depcruise": "depcruise packages apps --config .dependency-cruiser.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yaml,yml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@types/node": "26.1.1",
    "vite": "8.1.4",
    "tsup": {
      "esbuild": "0.25.12"
    }
  }
}
